<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.chart.*?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.trading.TradingController">
    <top>
        <VBox>
            <!-- Menu Bar -->
            <MenuBar>
                <menus>
                    <Menu mnemonicParsing="false" text="File">
                        <items>
                            <MenuItem mnemonicParsing="false" onAction="#handleNewPortfolio" text="New Portfolio" />
                            <MenuItem mnemonicParsing="false" onAction="#handleOpenPortfolio" text="Open Portfolio" />
                            <SeparatorMenuItem />
                            <MenuItem mnemonicParsing="false" onAction="#handleExportData" text="Export Data" />
                            <SeparatorMenuItem />
                            <MenuItem mnemonicParsing="false" onAction="#handleLogout" text="Logout" />
                            <MenuItem mnemonicParsing="false" onAction="#handleExit" text="Exit" />
                        </items>
                    </Menu>
                    <Menu mnemonicParsing="false" text="Portfolio">
                        <items>
                            <MenuItem mnemonicParsing="false" onAction="#handleBuyStock" text="Buy Stock" />
                            <MenuItem mnemonicParsing="false" onAction="#handleSellStock" text="Sell Stock" />
                            <SeparatorMenuItem />
                            <MenuItem mnemonicParsing="false" onAction="#handleViewTransactions" text="View Transactions" />
                        </items>
                    </Menu>
                    <Menu mnemonicParsing="false" text="Analysis">
                        <items>
                            <MenuItem mnemonicParsing="false" onAction="#handlePerformanceReport" text="Performance Report" />
                            <MenuItem mnemonicParsing="false" onAction="#handlePriceComparison" text="Price Comparison" />
                            <MenuItem mnemonicParsing="false" onAction="#handleAlerts" text="Manage Alerts" />
                        </items>
                    </Menu>
                    <Menu mnemonicParsing="false" text="Help">
                        <items>
                            <MenuItem mnemonicParsing="false" onAction="#handleAbout" text="About" />
                            <MenuItem mnemonicParsing="false" onAction="#handleUserGuide" text="User Guide" />
                        </items>
                    </Menu>
                </menus>
            </MenuBar>

            <!-- Toolbar -->
            <ToolBar>
                <items>
                    <Label text="Search Stock:" />
                    <TextField fx:id="stockSearchField" promptText="Enter symbol (e.g., AAPL)" prefWidth="200.0" />
                    <Button fx:id="searchButton" mnemonicParsing="false" onAction="#handleStockSearch" text="Search" />
                    <Separator orientation="VERTICAL" />
                    <Label text="Date Range:" />
                    <DatePicker fx:id="startDatePicker" promptText="Start Date" />
                    <Label text="to" />
                    <DatePicker fx:id="endDatePicker" promptText="End Date" />
                    <Button mnemonicParsing="false" onAction="#handleDateRangeUpdate" text="Update Chart" />
                    <Separator orientation="VERTICAL" />
                    <Label fx:id="statusLabel" text="Ready" />
                </items>
            </ToolBar>
        </VBox>
    </top>

    <center>
        <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE">
            <!-- Stock Search and Chart Tab -->
            <Tab text="Stock Analysis">
                <content>
                    <BorderPane>
                        <top>
                            <VBox spacing="10.0">
                                <padding>
                                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                </padding>

                                <!-- Stock Info Panel -->
                                <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #f8f9fa; -fx-background-radius: 5; -fx-padding: 15;">
                                    <children>
                                        <VBox alignment="CENTER_LEFT" spacing="5.0">
                                            <children>
                                                <Label fx:id="stockSymbolLabel" text="No stock selected" style="-fx-font-weight: bold; -fx-font-size: 18px;" />
                                                <Label fx:id="stockPriceLabel" text="" style="-fx-font-size: 24px; -fx-text-fill: #007bff;" />
                                            </children>
                                        </VBox>
                                        <Separator orientation="VERTICAL" />
                                        <VBox alignment="CENTER_LEFT" spacing="3.0">
                                            <children>
                                                <Label fx:id="stockChangeLabel" text="" />
                                                <Label fx:id="stockVolumeLabel" text="" />
                                                <Label fx:id="stockDateLabel" text="" />
                                            </children>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <VBox alignment="CENTER_RIGHT" spacing="10.0">
                                            <children>
                                                <Button fx:id="addToWatchlistButton" mnemonicParsing="false" onAction="#handleAddToWatchlist" text="Add to Watchlist" />
                                                <Button fx:id="buyStockButton" mnemonicParsing="false" onAction="#handleBuyStock" style="-fx-background-color: #28a745; -fx-text-fill: white;" text="Buy Stock" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                            </VBox>
                        </top>

                        <center>
                            <!-- Stock Price Chart -->
                            <LineChart fx:id="stockChart" animated="false" createSymbols="false" legendVisible="false">
                                <xAxis>
                                    <CategoryAxis fx:id="chartXAxis" label="Date" />
                                </xAxis>
                                <yAxis>
                                    <NumberAxis fx:id="chartYAxis" label="Price ($)" />
                                </yAxis>
                            </LineChart>
                        </center>

                        <bottom>
                            <!-- Additional Stock Details -->
                            <TableView fx:id="stockDetailsTable" prefHeight="150.0">
                                <columns>
                                    <TableColumn fx:id="dateColumn" prefWidth="100.0" text="Date" />
                                    <TableColumn fx:id="openColumn" prefWidth="80.0" text="Open" />
                                    <TableColumn fx:id="highColumn" prefWidth="80.0" text="High" />
                                    <TableColumn fx:id="lowColumn" prefWidth="80.0" text="Low" />
                                    <TableColumn fx:id="closeColumn" prefWidth="80.0" text="Close" />
                                    <TableColumn fx:id="volumeColumn" prefWidth="100.0" text="Volume" />
                                </columns>
                            </TableView>
                        </bottom>
                    </BorderPane>
                </content>
            </Tab>

            <!-- Portfolio Tab -->
            <Tab text="Portfolio">
                <content>
                    <BorderPane>
                        <top>
                            <VBox spacing="10.0">
                                <padding>
                                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                </padding>
                                <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #f8f9fa; -fx-background-radius: 5; -fx-padding: 15;">
                                    <children>
                                        <VBox alignment="CENTER_LEFT" spacing="5.0">
                                            <children>
                                                <Label text="Portfolio Value" style="-fx-font-weight: bold;" />
                                                <Label fx:id="portfolioValueLabel" text="$0.00" style="-fx-font-size: 20px; -fx-text-fill: #007bff;" />
                                            </children>
                                        </VBox>
                                        <Separator orientation="VERTICAL" />
                                        <VBox alignment="CENTER_LEFT" spacing="5.0">
                                            <children>
                                                <Label text="Total Gain/Loss" style="-fx-font-weight: bold;" />
                                                <Label fx:id="totalGainLossLabel" text="$0.00 (0.00%)" />
                                            </children>
                                        </VBox>
                                        <Separator orientation="VERTICAL" />
                                        <VBox alignment="CENTER_LEFT" spacing="5.0">
                                            <children>
                                                <Label text="Cash Balance" style="-fx-font-weight: bold;" />
                                                <Label fx:id="cashBalanceLabel" text="$10,000.00" style="-fx-font-size: 16px;" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                            </VBox>
                        </top>

                        <center>
                            <TableView fx:id="portfolioTable">
                                <columns>
                                    <TableColumn fx:id="portfolioSymbolColumn" prefWidth="80.0" text="Symbol" />
                                    <TableColumn fx:id="portfolioNameColumn" prefWidth="150.0" text="Company" />
                                    <TableColumn fx:id="portfolioSharesColumn" prefWidth="80.0" text="Shares" />
                                    <TableColumn fx:id="portfolioAvgPriceColumn" prefWidth="100.0" text="Avg Price" />
                                    <TableColumn fx:id="portfolioCurrentPriceColumn" prefWidth="100.0" text="Current Price" />
                                    <TableColumn fx:id="portfolioValueColumn" prefWidth="100.0" text="Market Value" />
                                    <TableColumn fx:id="portfolioGainLossColumn" prefWidth="100.0" text="Gain/Loss" />
                                    <TableColumn fx:id="portfolioGainLossPercentColumn" prefWidth="80.0" text="%" />
                                </columns>
                            </TableView>
                        </center>
                    </BorderPane>
                </content>
            </Tab>

            <!-- Watchlist Tab -->
            <Tab text="Watchlist">
                <content>
                    <BorderPane>
                        <top>
                            <ToolBar>
                                <items>
                                    <TextField fx:id="watchlistSearchField" promptText="Add symbol to watchlist" />
                                    <Button mnemonicParsing="false" onAction="#handleAddToWatchlist" text="Add" />
                                    <Separator orientation="VERTICAL" />
                                    <Button mnemonicParsing="false" onAction="#handleRefreshWatchlist" text="Refresh Prices" />
                                    <Button mnemonicParsing="false" onAction="#handleRemoveFromWatchlist" text="Remove Selected" />
                                </items>
                            </ToolBar>
                        </top>
                        <center>
                            <TableView fx:id="watchlistTable">
                                <columns>
                                    <TableColumn fx:id="watchlistSymbolColumn" prefWidth="80.0" text="Symbol" />
                                    <TableColumn fx:id="watchlistPriceColumn" prefWidth="100.0" text="Price" />
                                    <TableColumn fx:id="watchlistChangeColumn" prefWidth="100.0" text="Change" />
                                    <TableColumn fx:id="watchlistChangePercentColumn" prefWidth="100.0" text="Change %" />
                                    <TableColumn fx:id="watchlistVolumeColumn" prefWidth="100.0" text="Volume" />
                                    <TableColumn fx:id="watchlistLastUpdateColumn" prefWidth="120.0" text="Last Update" />
                                </columns>
                            </TableView>
                        </center>
                    </BorderPane>
                </content>
            </Tab>
        </TabPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #f8f9fa; -fx-padding: 8;">
            <children>
                <Label fx:id="connectionStatusLabel" text="Connected to Yahoo Finance" />
                <Separator orientation="VERTICAL" />
                <Label fx:id="userLabel" text="User: " />
                <Separator orientation="VERTICAL" />
                <Label fx:id="lastUpdateLabel" text="Last update: Never" />
                <Region HBox.hgrow="ALWAYS" />
                <ProgressIndicator fx:id="loadingIndicator" prefHeight="20.0" prefWidth="20.0" visible="false" />
            </children>
        </HBox>
    </bottom>
</BorderPane>