<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns="http://javafx.com/javafx/11.0.1"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.trading.LoginController"
           style="-fx-background-color: #0d1117;">

    <VBox alignment="CENTER" spacing="0" maxWidth="420" maxHeight="520"
          style="-fx-background-color: #161b22;
                 -fx-background-radius: 16;
                 -fx-border-color: #30363d;
                 -fx-border-radius: 16;
                 -fx-border-width: 1;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.6), 30, 0, 0, 8);">

        <!-- Header band -->
        <VBox alignment="CENTER" spacing="6"
              style="-fx-background-color: #1f2937;
                     -fx-background-radius: 16 16 0 0;
                     -fx-padding: 32 40 28 40;">
            <Label text="📈"
                   style="-fx-font-size: 38px;"/>
            <Label text="Trading System"
                   style="-fx-font-size: 22px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #f0f6fc;"/>
            <Label text="Sign in to your account"
                   style="-fx-font-size: 13px;
                          -fx-text-fill: #8b949e;"/>
        </VBox>

        <!-- Form area -->
        <VBox spacing="14" style="-fx-padding: 28 40 32 40;">

            <!-- Username -->
            <VBox spacing="6">
                <Label text="USERNAME"
                       style="-fx-font-size: 11px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #8b949e;
                              -fx-letter-spacing: 1px;"/>
                <TextField fx:id="usernameField"
                           promptText="Enter your username"
                           style="-fx-background-color: #0d1117;
                                  -fx-border-color: #30363d;
                                  -fx-border-radius: 8;
                                  -fx-background-radius: 8;
                                  -fx-text-fill: #f0f6fc;
                                  -fx-prompt-text-fill: #484f58;
                                  -fx-font-size: 14px;
                                  -fx-padding: 10 14 10 14;
                                  -fx-border-width: 1;"/>
            </VBox>

            <!-- Password -->
            <VBox spacing="6">
                <Label text="PASSWORD"
                       style="-fx-font-size: 11px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #8b949e;
                              -fx-letter-spacing: 1px;"/>
                <PasswordField fx:id="passwordField"
                               promptText="Enter your password"
                               style="-fx-background-color: #0d1117;
                                      -fx-border-color: #30363d;
                                      -fx-border-radius: 8;
                                      -fx-background-radius: 8;
                                      -fx-text-fill: #f0f6fc;
                                      -fx-prompt-text-fill: #484f58;
                                      -fx-font-size: 14px;
                                      -fx-padding: 10 14 10 14;
                                      -fx-border-width: 1;"/>
            </VBox>

            <!-- Status label -->
            <Label fx:id="statusLabel"
                   wrapText="true"
                   maxWidth="340"
                   style="-fx-font-size: 12px;
                          -fx-text-fill: #f85149;"/>

            <!-- Login button -->
            <Button fx:id="loginButton"
                    text="Sign In"
                    maxWidth="Infinity"
                    onAction="#handleLogin"
                    mnemonicParsing="false"
                    style="-fx-background-color: #238636;
                           -fx-text-fill: white;
                           -fx-font-size: 14px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-padding: 11 0 11 0;
                           -fx-cursor: hand;">
                <VBox.margin><Insets top="6"/></VBox.margin>
            </Button>

            <!-- Exit button -->
            <Button text="Exit"
                    maxWidth="Infinity"
                    onAction="#handleExit"
                    mnemonicParsing="false"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #8b949e;
                           -fx-font-size: 13px;
                           -fx-background-radius: 8;
                           -fx-border-color: #30363d;
                           -fx-border-radius: 8;
                           -fx-border-width: 1;
                           -fx-padding: 9 0 9 0;
                           -fx-cursor: hand;"/>

            <!-- Hint -->
            <Label text="Demo: admin / admin123"
                   style="-fx-font-size: 11px;
                          -fx-text-fill: #484f58;
                          -fx-alignment: center;"
                   maxWidth="Infinity"
                   alignment="CENTER">
                <VBox.margin><Insets top="4"/></VBox.margin>
            </Label>

        </VBox>
    </VBox>
</StackPane>
